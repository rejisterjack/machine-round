{
  "redirects": [
    {
      "source": "/docs/pitch-deck.html",
      "destination": "/pitch-deck.html",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/reset-stale-thinking",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/purge-orphan-media",
      "schedule": "0 4 * * 0"
    }
  ],
  "functions": {
    "app/api/evaluate/route.ts": {
      "maxDuration": 60
    },
    "app/api/interview/route.ts": {
      "maxDuration": 30
    },
    "app/api/reports/share/[token]/pdf/route.tsx": {
      "maxDuration": 30
    }
  }
}
