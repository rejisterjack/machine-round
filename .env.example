# Azure OpenAI resource
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Model deployments
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.1
AZURE_OPENAI_REALTIME_DEPLOYMENT=gpt-realtime-2.1
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Optional: separate Azure resource for Realtime (when chat and voice use different endpoints)
# AZURE_OPENAI_REALTIME_ENDPOINT=https://your-realtime-resource.openai.azure.com/
# AZURE_OPENAI_REALTIME_API_KEY=your-realtime-api-key

# Database (Neon PostgreSQL + pgvector for RAG question bank)
# Runtime: use the pooler URL. Migrations: set DIRECT_DATABASE_URL to the direct Neon host.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DIRECT_DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Optional: protect POST /api/admin/reseed-questions in development
# ADMIN_SECRET=your-dev-secret
