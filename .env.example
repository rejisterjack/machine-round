# Azure OpenAI resource
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Model deployments
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.1
AZURE_OPENAI_REALTIME_DEPLOYMENT=gpt-realtime-2.1
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Optional: separate Azure resource for Realtime (when chat and voice use different endpoints)
# AZURE_OPENAI_REALTIME_ENDPOINT=https://your-realtime-resource.openai.azure.com/
# AZURE_OPENAI_REALTIME_API_KEY=your-realtime-api-key

# Database (Neon PostgreSQL + pgvector for RAG question bank)
# Runtime: use the pooler URL. Migrations: set DIRECT_DATABASE_URL to the direct Neon host.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DIRECT_DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Optional: screen vision tuning (client-side)
# NEXT_PUBLIC_REALTIME_VISION_ENABLED=1
# NEXT_PUBLIC_SCREEN_PRECISION_ENABLED=1
# ADMIN_SECRET=your-dev-secret

# Auth.js (Google OAuth)
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:7329
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Cloudinary (screen snapshots + session recordings)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Or split vars:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional media optimization tuning
# Client bundle reads NEXT_PUBLIC_*; server APIs also accept MEDIA_* fallbacks.
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
# NEXT_PUBLIC_DEMO_SHARE_TOKEN=abc123sharetoken
# NEXT_PUBLIC_MEDIA_ARCHIVE_TARGET_KB=120
# NEXT_PUBLIC_MEDIA_RECORDING_VIDEO_KBPS=250
# NEXT_PUBLIC_MEDIA_RECORDING_MAX_HEIGHT=480
# MEDIA_ARCHIVE_TARGET_KB=120
# MEDIA_RECORDING_VIDEO_KBPS=250
# MEDIA_RECORDING_MAX_HEIGHT=480

# Smoke tests (optional — for authenticated E2E in CI/local)
# SMOKE_AUTH_COOKIE=next-auth.session-token=...
# SMOKE_AUTH_REQUIRED=1
# SMOKE_BASE_URL=http://localhost:7329

# Microsoft Clarity (session replay + heatmaps; production only)
# NEXT_PUBLIC_MICROSOFT_CLARITY_ID=your-clarity-project-id

# Share links (optional)
# SHARE_TOKEN_TTL_DAYS=90
# SHARE_PDF_RATE_LIMIT=20
# SHARE_PDF_RATE_WINDOW_MS=60000
